#Define module specific tests here

LOG_DIRECTORY="${LOG_DIRECTORY:-.log}"

01_make_start_test() {
    local action=make_start
    local name="Make Start Test"
    local description="This test runs make start and validates output for version information."
    local status=""
    local message=""
    local start_log_file="${LOG_DIRECTORY}/make_start.log"
    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Does make start execute without NOBRANCH or NOHASH output?\n"
    printf "        Are version identifiers properly configured?\n"
    printf "    Starting make start...\n"
    
    if ! make start >"$start_log_file" 2>&1; then
        status=$(bold $(red "FAILED"))
        message="        Make start command failed. See log: ${start_log_file}"
        tail "${start_log_file}"
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi
    make stop

    if ! make run cmd="ls -la">> "$start_log_file" 2>&1; then
        status=$(bold $(red "FAILED"))
        message="        Make run command failed. See log: ${start_log_file}"
        tail "${start_log_file}"
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi


    if grep -q "NOBRANCH\|NOHASH" "$start_log_file"; then
        status=$(startbold $(red "FAILED"))
        message="        Output contains NOBRANCH or NOHASH. See log: ${start_log_file}"
        grep "NOBRANCH\|NOHASH" "$start_log_file"
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi
    
    status=$(bold $(green "PASSED"))
    message="        Make start succeeded without version issues."
    printf "    Message:\n%s\n" "$message"
    printf "    %-77s %s\n" "Status:" "${status}"
    printf "    See the start log for more info: %s\n" "$start_log_file"
    exit 0
}

02_build_hello_world_test() {
    local action=build_hello_world
    local name="Build Hello World Test"
    local description="This test builds the ros2_hello_world package."
    local status=""
    local message=""
    local build_log_file="${LOG_DIRECTORY}/hello_world_build.log"

    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Does the hello world package compile without errors?\n"
    printf "        Are all dependencies resolved correctly?\n"
    printf "    Starting build...\n"

    if ! make run cmd="cd ros2_workspace/ && colcon build"; then
    #if ! make run cmd="cd ros2_workspace/ && colcon build" >"$build_log_file" 2>&1; then
        status=$(bold $(red "FAILED"))
        message="        Build failed. See log: ${build_log_file}"
        tail "${build_log_file}"
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi

    status=$(bold $(green "PASSED"))
    message="        Build succeeded."
    printf "    Message:\n%s\n" "$message"
    printf "    %-77s %s\n" "Status:" "${status}"
    printf "    See the build log for more info: %s\n" "$build_log_file"

    exit 0
}

03_rsyslog_test() {
    local action=rsyslog_test
    local name="Rsyslog Configuration Test"
    local description="This test validates rsyslog is properly configured to capture ROS2 messages."
    local status=""
    local message=""
    local log_file=".log/rsyslog/ros2_syslog.log"
    
    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Is rsyslog properly configured to capture tagged messages?\n"
    printf "        Are log files being created in the expected directory?\n"
    printf "        Are message contents being preserved correctly?\n"
    printf "    Starting rsyslog test...\n"
   
    if [ "$GITHUB_ACTIONS" = "true" ]; then
        echo "Running inside GitHub CI skipping rsyslog_test"
        exit 0
    fi

    rm -rf .log/rsyslog/ros2_syslog.log
    make start > /dev/null 2>&1;
    sleep 5s
    if ! make run cmd="logger --tag ros2 'Hello World'" > /dev/null 2>&1; then
        status=$(bold $(red "FAILED"))
        message="        Logger command failed."
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi
    sleep 2s
    
    if [[ ! -f "$log_file" ]]; then
        status=$(bold $(red "FAILED"))
        message="        Log file ${log_file} was not created."
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        make stop > /dev/null 2>&1;
        exit 1
    fi
    
    if ! grep -q "Hello World" "$log_file"; then
        status=$(bold $(red "FAILED"))
        message="        Message 'Hello World' not found in ${log_file}."
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        make stop > /dev/null 2>&1;
        exit 1
    fi
    
    status=$(bold $(green "PASSED"))
    message="        Rsyslog test succeeded. Log file created and message captured."
    printf "    Message:\n%s\n" "$message"
    printf "    %-77s %s\n" "Status:" "${status}"
    printf "    Log file: %s\n" "$log_file"
    make stop > /dev/null 2>&1;
    exit 0
}

04_x11_integration_test() {
    local action=x11_integration_test
    local name="X11 Integration Test"
    local description="Validates the display stack: DISPLAY var, X11 socket, xhost, xdpyinfo, and xeyes."
    local status=""
    local display_val=""
    local display_num=""
    local socket=""
    local cmd_out=""
    local cmd_rc=0

    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Is DISPLAY set inside the container?\n"
    printf "        Does the X11 socket exist for that display?\n"
    printf "        Is the X server accessible via xdpyinfo?\n"
    printf "        Can xeyes connect and render (full display pipeline)?\n"

    printf "    Starting Docker context...\n"
    if ! make start; then
        status=$(bold $(red "FAILED"))
        printf "    make start failed — cannot proceed with display checks.\n"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi

    printf "\n    --- DISPLAY variable ---\n"
    local container
    container=$(make container_name_adore_cli 2>/dev/null)
    display_val=$(docker exec "${container}" cat /tmp/.adore_display 2>/dev/null | grep -o 'DISPLAY=.*' | cut -d= -f2- | tail -1)
    if [ -z "${display_val}" ]; then
        status=$(bold $(red "FAILED"))
        printf "    DISPLAY is not set inside the container.\n"
        printf "    /tmp/.adore_display contents:\n"
        docker exec "${container}" cat /tmp/.adore_display 2>&1 || printf "    (file not found)\n"
        printf "    Container logs (tail):\n"
        docker logs "${container}" 2>&1 | tail -20
        printf "    %-77s %s\n" "Status:" "${status}"
        make stop
        exit 1
    fi
    printf "    DISPLAY=%s\n" "${display_val}"

    printf "\n    --- X11 socket ---\n"
    display_num="${display_val##*:}"
    display_num="${display_num%%.*}"
    socket="/tmp/.X11-unix/X${display_num}"
    if ! docker exec "${container}" test -S "${socket}" 2>/dev/null; then
        status=$(bold $(red "FAILED"))
        printf "    X11 socket %s does not exist inside the container.\n" "${socket}"
        printf "    If using host display: check /tmp/.X11-unix is mounted (-v /tmp/.X11-unix:/tmp/.X11-unix).\n"
        printf "    If using Xvfb: check that entrypoint.sh Xvfb started cleanly (check container logs).\n"
        docker logs "${container}" 2>&1 | tail -20
        printf "    %-77s %s\n" "Status:" "${status}"
        make stop
        exit 1
    fi
    printf "    X11 socket %s: found\n" "${socket}"

    printf "\n    --- xdpyinfo ---\n"
    cmd_out=$(docker exec -e DISPLAY="${display_val}" "${container}" xdpyinfo 2>&1)
    cmd_rc=$?
    if [ "${cmd_rc}" -ne 0 ]; then
        status=$(bold $(red "FAILED"))
        printf "    xdpyinfo failed (exit %d) on DISPLAY=%s\n" "${cmd_rc}" "${display_val}"
        printf "    xdpyinfo output:\n%s\n" "${cmd_out}"
        printf "    %-77s %s\n" "Status:" "${status}"
        make stop
        exit 1
    fi
    printf "    xdpyinfo: OK\n"

    printf "\n    --- xeyes ---\n"
    cmd_out=$(docker exec -e DISPLAY="${display_val}" "${container}" timeout 1 xeyes 2>&1)
    cmd_rc=$?
    if [ "${cmd_rc}" -ne 0 ] && [ "${cmd_rc}" -ne 124 ]; then
        status=$(bold $(red "FAILED"))
        printf "    xeyes failed (exit %d) on DISPLAY=%s\n" "${cmd_rc}" "${display_val}"
        printf "    xeyes output:\n%s\n" "${cmd_out}"
        printf "    %-77s %s\n" "Status:" "${status}"
        make stop
        exit 1
    fi
    printf "    xeyes: OK\n"

    status=$(bold $(green "PASSED"))
    printf "\n    Display stack fully functional:\n"
    printf "      DISPLAY=%s  socket=%s  xdpyinfo OK  xeyes OK\n" "${display_val}" "${socket}"
    printf "    %-77s %s\n" "Status:" "${status}"

    printf "    Stopping Docker context...\n"
    make stop
    exit 0
}

05_logs_test() {
    if ! make start > /dev/null 2>&1; then
        status=$(bold $(red "FAILED"))
        message="        Failed to start Docker context."
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi
    sleep 2s
    make logs > .log/adore_cli_docker_compose.log 2>&1
    make stop
    exit 0


}

