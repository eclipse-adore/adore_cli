#Define module specific tests here

LOG_DIRECTORY="${LOG_DIRECTORY:-.log}"

01_build_hello_world_test() {
    local action=build_hello_world
    local name="Build Hello World Test"
    local description="This test builds the ros2_hello_world package."
    local status=""
    local message=""
    local build_log_file="${LOG_DIRECTORY}/hello_world_build.log"

    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Does the hello world package compile without errors?\n"
    printf "        Are all dependencies resolved correctly?\n"
    printf "    Starting build...\n"

    if ! make run cmd="cd ros2_workspace/ && colcon build" >"$build_log_file" 2>&1; then
        status=$(bold $(red "FAILED"))
        message="        Build failed. See log: ${build_log_file}"
        tail "${build_log_file}"
        printf "    Message:\n%s\n" "$message"
        printf "    %-77s %s\n" "Status:" "${status}"
        exit 1
    fi

    status=$(bold $(green "PASSED"))
    message="        Build succeeded."
    printf "    Message:\n%s\n" "$message"
    printf "    %-77s %s\n" "Status:" "${status}"
    printf "    See the build log for more info: %s\n" "$build_log_file"

    exit 0
}

