source adore_cli.env
project=${PWD##*/}
build_directory="build"
log_directory=".log"
docker_image="$(make image_$project)"
docker_images=(
    $(make images_${project})
)
if [ "${ZENOH_ENABLE:-false}" = "true" ]; then
    docker_images+=("${ZENOH_IMAGE}")
fi
build_artifacts=(
    ${build_directory}/adore_cli_*.tar
)

log_files=(
    "${log_directory}/${project}.ci.log"
)
