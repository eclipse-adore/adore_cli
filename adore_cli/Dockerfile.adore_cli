ARG ADORE_CLI_BASE_IMAGE=adore_cli_base:latest
FROM ${ADORE_CLI_BASE_IMAGE}

ARG ROS_DISTRO=jazzy
ARG ARCH
ARG BRANCH
ARG SHORT_HASH
ARG PARENT_BRANCH
ARG PARENT_SHORT_HASH

LABEL org.adore.image-type="user" \
      org.adore.arch="${ARCH}" \
      org.adore.branch="${BRANCH}" \
      org.adore.commit="${SHORT_HASH}" \
      org.adore.parent-branch="${PARENT_BRANCH}" \
      org.adore.parent-commit="${PARENT_SHORT_HASH}"

COPY context/requirements.ppa    /tmp/build/
COPY context/requirements.system /tmp/build/
COPY context/requirements.pip3   /tmp/build/
COPY context/vendor/             /tmp/build/vendor/

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean && \
    if [ -s /tmp/build/requirements.ppa ]; then \
        apt-get install -y --no-install-recommends software-properties-common && \
        grep -v '^\s*#' /tmp/build/requirements.ppa | grep -v '^\s*$' | \
        while read -r ppa; do \
            add-apt-repository -y "$ppa"; \
        done; \
    fi && \
    apt-get update && \
    if [ -s /tmp/build/requirements.system ]; then \
        grep -v '^\s*#' /tmp/build/requirements.system | grep -v '^\s*$' | \
        envsubst | xargs -r apt-get install -y --no-install-recommends \
; \
    fi && \
    DEB_COUNT=$(find /tmp/build/vendor -maxdepth 1 -name '*.deb' | wc -l) && \
    if [ "$DEB_COUNT" -gt 0 ]; then \
        find /tmp/build/vendor -maxdepth 1 -name '*.deb' -print0 | \
            xargs -0 dpkg -i --force-all && \
        apt-get install -f -y --no-install-recommends \
; \
    fi

RUN python3 -m venv /opt/adore_venv --system-site-packages && \
    if [ -s /tmp/build/requirements.pip3 ]; then \
        grep -v '^\s*#' /tmp/build/requirements.pip3 | grep -v '^\s*$' | \
        xargs -r /opt/adore_venv/bin/pip install --upgrade; \
    fi

ENV PATH="/opt/adore_venv/bin:${PATH}"
ENV VIRTUAL_ENV="/opt/adore_venv"

RUN userdel --remove ubuntu 2>/dev/null || true

COPY files/rsyslog.conf.template /etc/rsyslog.conf.template
COPY files/entrypoint.sh         /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /tmp/adore
ENTRYPOINT ["/entrypoint.sh"]
